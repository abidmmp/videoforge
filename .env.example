# ───────────────────────────────────────────────────────────────
# VideoForge AI — Frontend environment template
# Copy to .env and fill in the values for your MoneyPrinterTurbo
# (MPT) backend deployment. All client-exposed variables must
# be prefixed with VITE_.
# ───────────────────────────────────────────────────────────────

# REST base URL of the MoneyPrinterTurbo FastAPI server.
VITE_API_BASE_URL=http://127.0.0.1:8080/api/v1

# WebSocket base URL (no trailing slash). Usually mirrors API host.
VITE_WS_BASE_URL=ws://127.0.0.1:8080/ws

# Optional bearer / API key forwarded as `Authorization: Bearer …`
# Leave blank for single-user desktop usage.
VITE_API_KEY=

# Request timeout in milliseconds for non-upload calls.
VITE_REQUEST_TIMEOUT=30000

# Maximum upload size (bytes). 512 MB default.
VITE_UPLOAD_LIMIT=536870912

# Number of automatic retries on 5xx / network errors.
VITE_API_MAX_RETRIES=2

# ── Feature flags ──────────────────────────────────────────────
# Toggle these to hide/expose UI surfaces that depend on backend
# capabilities. Do NOT gate critical render paths on these — they
# are presentation hints only.
VITE_FEATURE_RENDER=true
VITE_FEATURE_VOICE_CLONING=false
VITE_FEATURE_AI_IMAGES=false
VITE_FEATURE_CROSS_POSTING=false
VITE_FEATURE_CLOUD_RENDERING=false
VITE_FEATURE_CAPTIONS=true
VITE_FEATURE_TEMPLATES=true
VITE_FEATURE_ANALYTICS=false
VITE_FEATURE_SAAS=false

# Environment label shown in Developer Mode / About.
VITE_ENVIRONMENT=development
